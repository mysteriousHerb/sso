# your own subdomain
ISSUER=https://auth.example.com
# get it from https://admin.openai.com/identity
ALLOWED_REDIRECT_URIS=https://external.auth.openai.com/sso/oidc/your-connection/callback
# email domain for sign ups
ACCOUNT_DOMAIN=example.com
# put in the OPENAI SSO form at https://admin.openai.com/identity
OIDC_CLIENT_ID=openai-sso
OIDC_CLIENT_SECRET=replace-with-client-secret

OPENAI_LOGIN_URL=https://chatgpt.com/auth/login?sso=true&connection=conn_replace
# generate with node -e "crypto.subtle.generateKey({name:'RSASSA-PKCS1-v1_5',modulusLength:2048,publicExponent:new Uint8Array([1,0,1]),hash:'SHA-256'},true,['sign','verify']).then(k=>crypto.subtle.exportKey('jwk',k.privateKey)).then(j=>{j.kid='openai-sso-key';j.alg='RS256';j.use='sig';console.log(JSON.stringify(j))})"
PRIVATE_JWK={"kty":"RSA","kid":"replace-with-key-id","alg":"RS256","use":"sig"}

# generate inv code for 2fa
# curl -X POST https://你的網域/admin/invite-codes ^
#  -H "Authorization: Bearer 你的_ADMIN_TOKEN" ^
#  -H "Content-Type: application/json" ^
#  -d "{\"code\":\"JOIN-2026\",\"maxUses\":100}"
ADMIN_TOKEN=replace-with-admin-token

# TOKEN_TTL_SECONDS=3600
# TURNSTILE_SITE_KEY=0x4AAAAA...
# TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
# AUTHORIZATION_CODE_TTL_SECONDS=300


